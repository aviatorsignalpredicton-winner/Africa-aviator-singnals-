<!-- Firebase -->
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>

<script>
// Firebase config - replace with your own
const firebaseConfig = {
  apiKey: "YOUR_API_KEY",
  authDomain: "YOUR_PROJECT_ID.firebaseapp.com",
  databaseURL: "https://YOUR_PROJECT_ID.firebaseio.com",
  projectId: "YOUR_PROJECT_ID",
  storageBucket: "YOUR_PROJECT_ID.appspot.com",
  messagingSenderId: "SENDER_ID",
  appId: "APP_ID"
};

firebase.initializeApp(firebaseConfig);
const db = firebase.database();

const adminEmail = "kevinkipkorir212001@gmail.com";
const adminPass = "462355";

let signals = [];
let countdownSec = 15;
let animating=false;
let targetMultiplier=0;

const canvas = document.getElementById("planeCanvas");
const ctx = canvas.getContext("2d");
let planeY = 280;

// Pages
function showPage(page){
  document.getElementById("home").classList.add("hidden");
  document.getElementById("signals").classList.add("hidden");
  document.getElementById("login").classList.add("hidden");
  document.getElementById("admin").classList.add("hidden");
  document.getElementById(page).classList.remove("hidden");
}

// Admin login
function login(){
  let email = document.getElementById("email").value.trim();
  let pass = document.getElementById("password").value;
  if(email===adminEmail && pass===adminPass){
    showPage("admin");
  } else {
    document.getElementById("error").innerText="Wrong login";
  }
}

// Post signal to Firebase
function postSignal(){
  let sig = document.getElementById("signalInput").value;
  if(sig==="") return;
  db.ref("signals").push(sig);
  document.getElementById("signalInput").value="";
  alert("Signal posted");
}

// Listen for signals in real time
db.ref("signals").on("value", snapshot=>{
  signals=[];
  snapshot.forEach(child=>{
    signals.unshift(child.val());
  });
  updateDashboard();
  if(signals.length>0){
    startCrashAnimation(signals[0]);
  }
});

// Update dashboard
function updateDashboard(){
  const latest=document.getElementById("latestSignal");
  latest.innerText=signals[0]||"Waiting...";
  latest.className="signal"+(signals[0]&&signals[0].includes("5")?" high":"");

  const historyEl=document.getElementById("history");
  historyEl.innerHTML="";
  signals.forEach(s=>{
    let li=document.createElement("li");
    li.innerText=s;
    li.style.color = s.includes("✅")?"#22c55e":"#ef4444";
    historyEl.appendChild(li);
  });

  let wins = signals.filter(s=>s.includes("✅")).length;
  let losses = signals.filter(s=>s.includes("❌")).length;
  let acc = signals.length?Math.round((wins/signals.length)*100):0;
  document.getElementById("wins").innerText=wins;
  document.getElementById("losses").innerText=losses;
  document.getElementById("accuracy").innerText=acc+"%";
}

// Countdown
setInterval(()=>{
  countdownSec--;
  if(countdownSec<=0) countdownSec=15;
  document.getElementById("countdown").innerText="Next signal in "+countdownSec+"s";
},1000);

// Crash plane animation
function startCrashAnimation(signal){
  let num=parseFloat(signal);
  if(isNaN(num)) return;
  targetMultiplier=num;
  planeY=280;
  if(!animating) animating=true;
  animatePlane();
}

function animatePlane(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  ctx.fillStyle="#22c55e";
  ctx.fillRect(180,planeY,40,40);
  ctx.fillStyle="white";
  ctx.font="20px Arial";
  ctx.fillText(signals[0]||"0x",190,planeY-10);

  if(animating){
    let step = 280/(targetMultiplier*20);
    planeY -= step;
    if(planeY>280 - targetMultiplier*40){
      requestAnimationFrame(animatePlane);
    } else animating=false;
  }
}

updateDashboard();
</script>

</body>
